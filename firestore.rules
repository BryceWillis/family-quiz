rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Sessions: any signed-in (including anonymous) user can read/write.
    // All players sign in anonymously via Firebase Auth before accessing data.
    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;

      match /players/{playerId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
